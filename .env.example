# ============================================================
# PROJECT BORG — API KEY MANIFEST
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================================

# --- Firebase (Firestore + Auth + Storage) ---
# Setup: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Google Gemini API (Agent LLM) ---
# Setup: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key
# Models: gemini-2.0-flash (routing/fast), gemini-2.0-pro (synthesis)
VITE_GEMINI_ROUTING_MODEL=gemini-2.0-flash
VITE_GEMINI_SYNTHESIS_MODEL=gemini-2.0-pro

# --- Pinecone (Vector DB for RAG) ---
# Setup: https://app.pinecone.io
VITE_PINECONE_API_KEY=your_pinecone_api_key
VITE_PINECONE_ENVIRONMENT=your_pinecone_environment
VITE_PINECONE_INDEX_NAME=borg-org-knowledge

# --- Optional: Redis (Inter-Agent Pub/Sub — Phase 2) ---
# Recommended: Upstash Redis (serverless, free tier)
# Setup: https://upstash.com
VITE_UPSTASH_REDIS_URL=your_upstash_redis_url
VITE_UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# --- Optional: LinkedIn OAuth (Profile Connect — Phase 2) ---
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id
