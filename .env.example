# ================================================================
# PROJECT BORG — ENVIRONMENT VARIABLES
# Copy to .env — never commit .env to git
# ================================================================

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Gemini (Agent LLM) ---
# https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# --- Pinecone (Vector DB / RAG) ---
# https://app.pinecone.io
VITE_PINECONE_API_KEY=
VITE_PINECONE_ENVIRONMENT=
VITE_PINECONE_INDEX_NAME=borg-knowledge

# --- Upstash Redis (Inter-Agent Pub/Sub — Phase 2) ---
# https://upstash.com
VITE_UPSTASH_REDIS_URL=
VITE_UPSTASH_REDIS_TOKEN=

# --- Google OAuth (Calendar integration — Phase 2) ---
VITE_GOOGLE_CLIENT_ID=

# --- LinkedIn OAuth (Profile enrichment — Phase 2) ---
VITE_LINKEDIN_CLIENT_ID=

# --- Feature Flags ---
VITE_USE_MOCK=true
VITE_ENABLE_INTERNAL_MONOLOGUE=false
VITE_HIDE_ORG_DATA_UI=false
