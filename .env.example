# Project Borg — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env — it is gitignored.

# ─── Firebase ──────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Google Gemini ─────────────────────────────────────────
# Used for: LLM responses (gemini-2.5-flash-lite) + embeddings (text-embedding-004)
# Restrict this key to your domain in Google Cloud Console for production.
VITE_GEMINI_API_KEY=

# ─── Pinecone ──────────────────────────────────────────────
# Index must be 768-dimensional, cosine similarity metric.
# Index name should match VITE_PINECONE_INDEX below.
VITE_PINECONE_API_KEY=
VITE_PINECONE_INDEX=borg-org-knowledge

# ─── Feature Flags ─────────────────────────────────────────
# Set VITE_USE_MOCK=true to run the full UI without any API keys.
# Pre-seeded mock data activates — safe for demo environments.
VITE_USE_MOCK=false
